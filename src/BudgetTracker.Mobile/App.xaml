<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="BudgetTracker.Mobile.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:BudgetTracker.Mobile.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:TransactionAmountColorConverter x:Key="TransactionAmountColorConverter" />
            <converters:TransactionSignConverter x:Key="TransactionSignConverter" />
            <converters:ProgressToDecimalConverter x:Key="ProgressToDecimalConverter" />
            <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
