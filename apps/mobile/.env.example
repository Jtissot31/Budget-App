# Budget Tracker Mobile — variables d'environnement

# Empêche Expo / Metro d'ouvrir Edge ou Chrome automatiquement
BROWSER=none

# Gemini Flash 2.5 — RFA, alertes batch, plans (background)
EXPO_PUBLIC_GEMINI_API_KEY=

# Claude Sonnet 4.5 — chat conseiller financier
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# Copier ce fichier vers `.env` dans ce dossier (apps/mobile/) et renseigner les clés.
# Puis redémarrer Expo avec cache vidé : npm start -- --clear
# Sans clés, l'app fonctionne en mode démo avec résumés locaux.
